# Copy to Pulumi.dev.yaml and fill in your project ID, then:
#   pulumi stack init dev
#   pulumi up
config:
  stackit-nuke-dev-infra:projectId: 00000000-0000-0000-0000-000000000000
  stackit-nuke-dev-infra:region: eu01
  stackit-nuke-dev-infra:availabilityZone: eu01-1
  stackit-nuke-dev-infra:machineType: g2i.1
  stackit-nuke-dev-infra:serverCount: "2"
